PrecheckDeviceStorage =
SELECTCOLUMNS (
    FILTER (
        ipu_device_preCheck_raw_logs_infx,
        ipu_device_preCheck_raw_logs_infx[pre_check_actor]
            IN { "check_boot_filesystem", "custom_boot_filesystem" }
    ),
    "hostname", ipu_device_preCheck_raw_logs_infx[pre_Check_Host],
    "summary",  ipu_device_preCheck_raw_logs_infx[pre_Check_Summary]
)

BootSpace =
VAR txt         = [summary]
VAR startPos    = FIND ( "Available Size:", txt, 1, BLANK() ) + LEN ( "Available Size:" )
VAR endPos      = FIND ( " MB", txt, startPos, BLANK() )
RETURN
IF (
    ISBLANK ( startPos ) || ISBLANK ( endPos ),
    BLANK(),
    VALUE ( MID ( txt, startPos, endPos - startPos ) )
)

BootSize =
VAR txt         = [summary]
VAR startPos    = FIND ( "Total Size:", txt, 1, BLANK() ) + LEN ( "Total Size:" )
VAR endPos      = FIND ( " MB", txt, startPos, BLANK() )
RETURN
IF (
    ISBLANK ( startPos ) || ISBLANK ( endPos ),
    BLANK(),
    VALUE ( MID ( txt, startPos, endPos - startPos ) )
)
