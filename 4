@echo off
REM ────────────────────────────────────
REM  Build & Package InfinexUI
REM ────────────────────────────────────

REM 1) Log setup
set LOG_FILE=ui_build_log.txt
echo ======================================= >> %LOG_FILE%
echo Build started at %date% %time%      >> %LOG_FILE%

REM 2) Main work
call :main >> %LOG_FILE% 2>&1
exit /b

:main
  REM — platform & paths
  set GOOS=linux
  set GOARCH=amd64
  set OUTPUT_DIR=ui_build
  set BINARY_NAME=infxui

  REM 3) Cleanup previous
  if exist %OUTPUT_DIR% rmdir /s /q %OUTPUT_DIR%
  mkdir %OUTPUT_DIR%

  REM 4) Compile Go server
  echo Compiling Go binary for %GOOS%/%GOARCH%...
  go build -o %OUTPUT_DIR%\%BINARY_NAME% main.go
  if errorlevel 1 (
    echo Go build failed! 
    exit /b 1
  )
  echo Go binary created: %OUTPUT_DIR%\%BINARY_NAME%

  REM 5) (Optional) compress binary
  echo Compressing binary...
  tar -czf %OUTPUT_DIR%\%BINARY_NAME%.tar.gz -C %OUTPUT_DIR% %BINARY_NAME%

  REM 6) Copy all frontend assets
  echo Copying 'static\' → '%OUTPUT_DIR%\static\'...
  xcopy /s /y /i static %OUTPUT_DIR%\static
  if errorlevel 1 (
    echo Static assets copy failed!
    exit /b 1
  )

  REM 7) Copy extra app folders (if you have them)
  if exist appconfig (
    echo Copying 'appconfig\' → '%OUTPUT_DIR%\appconfig\'...
    xcopy /s /y /i appconfig %OUTPUT_DIR%\appconfig
  )
  if exist applogs (
    echo Copying 'applogs\'   → '%OUTPUT_DIR%\applogs\'...
    xcopy /s /y /i applogs   %OUTPUT_DIR%\applogs
  )

REM 7) Copy everything to your backup directory
  set DEST_DIR="C:\Users\k117655\OneDrive - Wells Fargo\Code backup\InfinexUI"
  if not exist %DEST_DIR% (
    mkdir %DEST_DIR%
  )
  echo Copying build output → %DEST_DIR%...
  xcopy /s /y /i "%OUTPUT_DIR%\*" %DEST_DIR%
  if errorlevel 1 (
    echo Backup copy failed!
    exit /b 1
  )

echo Build & packaging completed.

exit /b
