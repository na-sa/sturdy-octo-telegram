package main

import (
	"crypto/tls"
	"log"
	"net/http"
	"os"

	"github.com/gin-gonic/gin"
)

func main() {
	// 1) Build your Gin router as usual
	gin.SetMode(gin.ReleaseMode)
	r := gin.New()
	r.Use(gin.Logger(), gin.Recovery())
	api.RegisterRoutes(r) // your API routes under /api

	// 2) Decide HTTP vs HTTPS by env var
	useTLS := os.Getenv("USE_TLS") == "true"
	addr := ":8080"

	if useTLS {
		// 3) Load & decrypt your cert/key
		pass := os.Getenv("TLS_KEY_PASSPHRASE") // pick this up from env
		cert, err := loadTLSCert(
			"./certs/fullchain.pem",                      // cert PEM
			"./certs/ilhcev4150g380u.wellsfargo.net.key", // encrypted key PEM
			pass,
		)
		if err != nil {
			log.Fatalf("failed to load TLS cert: %v", err)
		}

		// 4) Create a custom HTTP server with our in-memory cert
		server := &http.Server{
			Addr:    ":443", // override port for HTTPS
			Handler: r,
			TLSConfig: &tls.Config{
				Certificates: []tls.Certificate{cert},
			},
		}

		log.Printf("🚀 Starting HTTPS on %s", server.Addr)
		// the empty strings here tell Go to use TLSConfig.Certificates
		if err := server.ListenAndServeTLS("", ""); err != nil {
			log.Fatalf("HTTPS failed: %v", err)
		}
	} else {
		log.Printf("🚀 Starting HTTP on %s", addr)
		if err := r.Run(addr); err != nil {
			log.Fatalf("HTTP failed: %v", err)
		}
	}
}
