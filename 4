package amelia

import (
	"bytes"
	"context"
	"encoding/json"
	"errors"
	"fmt"
	"net/http"
	"sync"
	"time"

	"golang.org/x/oauth2/clientcredentials"
)

// AmeliaConfig holds your auth and request settings.
// auth_url should be the full token endpoint (e.g. https://apiIDP-…/oauth/token).
// events_url is the constant endpoint for firing workflows.
type AmeliaConfig struct {
	AuthURL      string        `mapstructure:"auth_url"`
	ClientID     string        `mapstructure:"client_id"`
	ClientSecret string        `mapstructure:"client_secret"`
	TokenTTL     time.Duration `mapstructure:"token_ttl"`
	EventsURL    string        // e.g. "https://…/amelia-automation-ingress/v1/Events"
}

// TriggerRequest is the body you send to /Events
type TriggerRequest struct {
	ReferenceID string                 `json:"referenceId"` // e.g. "os_stats_<uuid>"
	RequestType string                 `json:"requestType"` // e.g. "fetch_ctasks"
	Payload     map[string]interface{} `json:"payload" binding:"required"`
}

// AmeliaResponse captures the standard Amelia reply.
type AmeliaResponse struct {
	Message struct {
		Code int    `json:"code"`
		Type string `json:"type"`
	} `json:"message"`
	Data struct {
		RequestID string `json:"requestId"`
		TraceID   string `json:"traceId"`
		ID        string `json:"id"`
	} `json:"data"`
}

// Client is your lightweight Amelia API client with caching.
type Client struct {
	cfg     AmeliaConfig
	http    *http.Client
	token   string
	expires time.Time
	mu      sync.Mutex
}

// NewClient builds a Client that will fetch & cache tokens.
func NewClient(cfg AmeliaConfig) *Client {
	cc := clientcredentials.Config{
		ClientID:     cfg.ClientID,
		ClientSecret: cfg.ClientSecret,
		TokenURL:     cfg.AuthURL,
	}
	return &Client{
		cfg:  cfg,
		http: cc.Client(context.Background()),
	}
}

// getToken ensures we have a non-expired token.
func (c *Client) getToken(ctx context.Context) (string, error) {
	c.mu.Lock()
	defer c.mu.Unlock()

	// if we still have a valid token, reuse it
	if time.Now().Before(c.expires) && c.token != "" {
		return c.token, nil
	}

	// fetch a fresh one
	req, _ := http.NewRequestWithContext(ctx, "POST", c.cfg.AuthURL, bytes.NewBufferString("grant_type=client_credentials"))
	req.Header.Set("Content-Type", "application/x-www-form-urlencoded")

	// clientcredentials.Client will auto-add Basic Auth
	resp, err := c.http.Do(req)
	if err != nil {
		return "", fmt.Errorf("amelia: token request failed: %w", err)
	}
	defer resp.Body.Close()

	if resp.StatusCode != http.StatusOK {
		return "", fmt.Errorf("amelia: token request returned %d", resp.StatusCode)
	}

	var tok struct {
		AccessToken string `json:"access_token"`
		ExpiresIn   int    `json:"expires_in"`
	}
	if err := json.NewDecoder(resp.Body).Decode(&tok); err != nil {
		return "", fmt.Errorf("amelia: token parse failed: %w", err)
	}
	if tok.AccessToken == "" {
		return "", errors.New("amelia: empty access token")
	}

	c.token = tok.AccessToken
	// use real TTL if given, else fall back to config
	ttl := c.cfg.TokenTTL
	if tok.ExpiresIn > 0 {
		ttl = time.Duration(tok.ExpiresIn) * time.Second
	}
	c.expires = time.Now().Add(ttl - time.Second) // slack 1s

	return c.token, nil
}

// Trigger fires off your workflow, returns the raw Amelia response.
func (c *Client) Trigger(ctx context.Context, reqBody TriggerRequest) (*AmeliaResponse, error) {
	// ensure we have a ReferenceID
	if reqBody.ReferenceID == "" {
		return nil, errors.New("amelia: ReferenceID required")
	}

	// get bearer token
	token, err := c.getToken(ctx)
	if err != nil {
		return nil, err
	}

	// marshal JSON
	bodyBytes, err := json.Marshal(reqBody)
	if err != nil {
		return nil, fmt.Errorf("amelia: payload marshal failed: %w", err)
	}

	// fire request
	httpReq, _ := http.NewRequestWithContext(ctx, "POST", c.cfg.EventsURL, bytes.NewReader(bodyBytes))
	httpReq.Header.Set("Authorization", "Bearer "+token)
	httpReq.Header.Set("Content-Type", "application/json")

	resp, err := c.http.Do(httpReq)
	if err != nil {
		return nil, fmt.Errorf("amelia: trigger request failed: %w", err)
	}
	defer resp.Body.Close()

	if resp.StatusCode != http.StatusAccepted && resp.StatusCode != http.StatusOK {
		return nil, fmt.Errorf("amelia: trigger returned %d", resp.StatusCode)
	}

	var ar AmeliaResponse
	if err := json.NewDecoder(resp.Body).Decode(&ar); err != nil {
		return nil, fmt.Errorf("amelia: response parse failed: %w", err)
	}
	return &ar, nil
}
